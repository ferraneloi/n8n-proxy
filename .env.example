# ============================================================
# Docker / n8n
# ============================================================
N8N_VERSION=2.13.4

POSTGRES_USER=pguser
POSTGRES_PASSWORD=pgpass
POSTGRES_DB=n8n

POSTGRES_NON_ROOT_USER=pguser
POSTGRES_NON_ROOT_PASSWORD=pgpass

RUNNERS_AUTH_TOKEN=change-this-runner-auth-token

# ============================================================
# Tunnel / Render Proxy
# ============================================================

# URL de tu servicio en Render (el proxy estable en la nube)
# Obtén esta URL después de crear el Web Service en Render
RENDER_URL=https://tu-servicio.onrender.com

# Token para autenticar el registro del túnel
# Debe coincidir con el CONFIG_TOKEN configurado en Render
CONFIG_TOKEN=change-this-secret-token

# Puerto del servidor proxy (solo relevante en Render, no tocar)
PORT=3000
