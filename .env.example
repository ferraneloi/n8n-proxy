# N8N Proxy Configuration

# Entorno local (usa http://localhost:3000 por defecto)
# Para producción en Render, usa la URL de tu servicio en Render
PUBLIC_URL=http://localhost:3000

# URL donde está n8n (en local es http://localhost:5678)
# En producción, cambiar a la URL de tu n8n en Render
TARGET_URL=http://localhost:5678

# Path del webhook en n8n (puedes verlo en la configuración de tu webhook)
# Ejemplo: /webhook/3bffaaea-4f6d-4e80-bf54-ca08a3a7c72b
WEBHOOK_PATH=/webhook/test

# Token para proteger el endpoint /api/config
CONFIG_TOKEN=mysecret

# Puerto del servidor proxy
PORT=3000

# Entorno
NODE_ENV=development
